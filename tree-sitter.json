        "ahk",
        "ah2",
        "ahk2"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "AutoHotkey v2 grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-ahk2"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
